---
import { getPluginNavItem } from "../../plugin-nav";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("tooltip")!;
const buttonClasses =
  "inline-flex min-w-28 items-center justify-center rounded-md border border-input bg-background px-3 py-2 text-sm font-medium hover:bg-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-ring";
const tooltipClasses =
  "pointer-events-none z-[60] whitespace-nowrap rounded-md border bg-popover px-3 py-1.5 text-xs text-popover-foreground shadow-md";
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div
		class="grid gap-8"
		x-data="{
			demos: [
				{ id: 'tip-top', placement: 'top', label: 'Top', text: 'Top placement' },
				{ id: 'tip-top-start', placement: 'top-start', label: 'Top start', text: 'Top start' },
				{ id: 'tip-top-end', placement: 'top-end', label: 'Top end', text: 'Top end' },
				{ id: 'tip-bottom', placement: 'bottom', label: 'Bottom', text: 'Bottom placement' },
				{ id: 'tip-bottom-start', placement: 'bottom-start', label: 'Bottom start', text: 'Bottom start' },
				{ id: 'tip-bottom-end', placement: 'bottom-end', label: 'Bottom end', text: 'Bottom end' },
				{ id: 'tip-left', placement: 'left', label: 'Left', text: 'Left placement' },
				{ id: 'tip-right', placement: 'right', label: 'Right', text: 'Right placement' },
			],
		}"
		x-init="demos.forEach(d => $store.tooltip.register(d.id, { openDelay: 0, closeDelay: 80 }))"
	>
		<div>
			<h3 class="text-sm font-medium mb-2">Placement variants</h3>
			<p class="text-xs text-muted-foreground mb-4">
				Hover or focus each trigger. Positioned with <code>@alpinejs/anchor</code>. Active:
				<strong
					x-text="demos.find(d => $store.tooltip.isOpen(d.id))?.placement ?? '—'"
				></strong>
			</p>

			<div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
				<template x-for="demo in demos" :key="demo.id">
					<div
						class="flex flex-col items-center gap-2 rounded-lg border border-dashed p-4"
						x-data="{
							id: demo.id,
							placement: demo.placement,
							text: demo.text,
							label: demo.label,
						}"
					>
						<div x-ref="triggerWrap">
							<button
								type="button"
								class={buttonClasses}
								x-bind:aria-describedby="id + '-tooltip'"
								@mouseenter="$store.tooltip.showOnHover(id)"
								@mouseleave="$store.tooltip.hideOnHover(id)"
								@focus="$store.tooltip.showOnFocus(id)"
								@blur="$store.tooltip.hideOnFocus(id)"
								@keydown.escape="$store.tooltip.handleKeydown(id, $event)"
								x-text="label"
							></button>
						</div>
						<code class="text-[10px] text-muted-foreground" x-text="placement"></code>

						<template x-if="placement === 'top'">
							<div
								x-bind:id="id + '-tooltip'"
								x-show="$store.tooltip.isOpen(id)"
								x-transition.opacity.duration.150ms
								x-anchor.top.fixed.offset.8="$refs.triggerWrap"
								role="tooltip"
								class={tooltipClasses}
								x-text="text"
							></div>
						</template>
						<template x-if="placement === 'top-start'">
							<div
								x-bind:id="id + '-tooltip'"
								x-show="$store.tooltip.isOpen(id)"
								x-transition.opacity.duration.150ms
								x-anchor.top-start.fixed.offset.8="$refs.triggerWrap"
								role="tooltip"
								class={tooltipClasses}
								x-text="text"
							></div>
						</template>
						<template x-if="placement === 'top-end'">
							<div
								x-bind:id="id + '-tooltip'"
								x-show="$store.tooltip.isOpen(id)"
								x-transition.opacity.duration.150ms
								x-anchor.top-end.fixed.offset.8="$refs.triggerWrap"
								role="tooltip"
								class={tooltipClasses}
								x-text="text"
							></div>
						</template>
						<template x-if="placement === 'bottom'">
							<div
								x-bind:id="id + '-tooltip'"
								x-show="$store.tooltip.isOpen(id)"
								x-transition.opacity.duration.150ms
								x-anchor.bottom.fixed.offset.8="$refs.triggerWrap"
								role="tooltip"
								class={tooltipClasses}
								x-text="text"
							></div>
						</template>
						<template x-if="placement === 'bottom-start'">
							<div
								x-bind:id="id + '-tooltip'"
								x-show="$store.tooltip.isOpen(id)"
								x-transition.opacity.duration.150ms
								x-anchor.bottom-start.fixed.offset.8="$refs.triggerWrap"
								role="tooltip"
								class={tooltipClasses}
								x-text="text"
							></div>
						</template>
						<template x-if="placement === 'bottom-end'">
							<div
								x-bind:id="id + '-tooltip'"
								x-show="$store.tooltip.isOpen(id)"
								x-transition.opacity.duration.150ms
								x-anchor.bottom-end.fixed.offset.8="$refs.triggerWrap"
								role="tooltip"
								class={tooltipClasses}
								x-text="text"
							></div>
						</template>
						<template x-if="placement === 'left'">
							<div
								x-bind:id="id + '-tooltip'"
								x-show="$store.tooltip.isOpen(id)"
								x-transition.opacity.duration.150ms
								x-anchor.left.fixed.offset.8="$refs.triggerWrap"
								role="tooltip"
								class={tooltipClasses}
								x-text="text"
							></div>
						</template>
						<template x-if="placement === 'right'">
							<div
								x-bind:id="id + '-tooltip'"
								x-show="$store.tooltip.isOpen(id)"
								x-transition.opacity.duration.150ms
								x-anchor.right.fixed.offset.8="$refs.triggerWrap"
								role="tooltip"
								class={tooltipClasses}
								x-text="text"
							></div>
						</template>
					</div>
				</template>
			</div>
		</div>

		<div
			x-data="{}"
			x-init="$store.tooltip.register('tip-scroll', { openDelay: 0, closeDelay: 0 })"
		>
			<h3 class="text-sm font-medium mb-2">Scroll test</h3>
			<p class="text-xs text-muted-foreground mb-3">
				Hover the trigger, then scroll inside the box — <code>x-anchor.fixed</code> with
				<code>x-teleport</code> keeps the tooltip anchored while scrolling.
			</p>
			<div class="h-40 overflow-auto rounded-lg border p-6">
				<div class="flex h-64 items-center justify-center">
					<div x-ref="scrollTriggerWrap">
						<button
							type="button"
							class={buttonClasses}
							aria-describedby="tip-scroll-tooltip"
							@mouseenter="$store.tooltip.showOnHover('tip-scroll')"
							@mouseleave="$store.tooltip.hideOnHover('tip-scroll')"
							@focus="$store.tooltip.showOnFocus('tip-scroll')"
							@blur="$store.tooltip.hideOnFocus('tip-scroll')"
						>
							Hover &amp; scroll
						</button>
					</div>
				</div>
			</div>

			<template x-teleport="body">
				<div
					id="tip-scroll-tooltip"
					x-show="$store.tooltip.isOpen('tip-scroll')"
					x-transition.opacity.duration.150ms
					x-anchor.top.fixed.offset.8="$refs.scrollTriggerWrap"
					role="tooltip"
					class={tooltipClasses}
				>
					Follows anchor on scroll
				</div>
			</template>
		</div>

		<div>
			<h3 class="text-sm font-medium mb-2">Notes</h3>
			<ul class="text-xs text-muted-foreground list-disc pl-5 space-y-1">
				<li>Pair with <code>@alpinejs/anchor</code> — store handles open/close, delays, and Escape</li>
				<li>Use <code>x-anchor.fixed</code> for teleported panels and scrollable containers</li>
			</ul>
		</div>
	</div>

	<p class="text-xs text-muted-foreground mt-6">Package: <code>{plugin.package}</code></p>
</DemoSection>
