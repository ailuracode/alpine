---
import Button from "../astro/Button.astro";
import DemoSection from "../DemoSection.astro";
---

<DemoSection title="Calendar" api="$calendar">
	<div x-data="calendarDemo">
		<div class="flex flex-wrap items-center gap-2">
			<Button @click="cal.prevMonth()">Previous</Button>
			<strong x-text="cal.formatMonth()"></strong>
			<Button @click="cal.nextMonth()">Next</Button>
			<Button @click="cal.goToToday()">Today</Button>
		</div>

		<div class="grid grid-cols-7 gap-1 mt-3">
			<template x-for="label in cal.weekdayLabels" :key="label">
				<span class="text-center text-xs font-semibold text-muted-foreground py-1" x-text="label"></span>
			</template>
		</div>

		<template x-for="week in cal.weeks" :key="week[0].date.toISOString()">
			<div class="grid grid-cols-7 gap-1">
				<template x-for="day in week" :key="day.date.toISOString()">
					<button
						type="button"
						class="inline-flex size-8 items-center justify-center rounded-lg text-sm tabular-nums hover:bg-muted disabled:opacity-50"
						x-bind:disabled="day.isDisabled"
						x-bind:class="{ 'opacity-45': !day.isCurrentMonth, 'border border-primary text-primary': day.isToday && !day.isSelected, 'bg-primary text-primary-foreground': day.isSelected }"
						@click="cal.select(day.date)"
						x-text="cal.format(day.date, 'd')"
					></button>
				</template>
			</div>
		</template>

		<p class="text-sm text-green-600 dark:text-green-400 mt-3" x-show="cal.selected" x-cloak>
			Selected:
			<strong x-text="cal.format(cal.selected, 'PPP')"></strong>
		</p>
		<p class="text-sm text-muted-foreground mt-2">
			Weekends are disabled via <code>disabled: &#123; dayOfWeek: [0, 6] &#125;</code>.
		</p>
	</div>
</DemoSection>
