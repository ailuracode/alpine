---
import { badgeVariants } from "@/components/ui/badge";
import { cn } from "@/lib/utils";
import Button from "../astro/Button.astro";
import DemoSection from "../DemoSection.astro";
---

<DemoSection title="Toggle" api="$toggle">
	<div class="grid gap-4">
		<div x-data="toggleBinaryDemo">
			<p>
				Binary:
				<strong x-text="power.value"></strong>
			</p>
			<div class="flex flex-wrap gap-2 mt-2">
				<Button @click="power.toggle()">Toggle</Button>
				<Button @click="power.cycle()">Cycle</Button>
				<span
					class={cn(badgeVariants({ variant: "outline" }))}
					x-bind:class="{ 'bg-primary text-primary-foreground': power.is(power.truly), 'text-muted-foreground': power.is(power.falsely) }"
					x-text="power.value"
				></span>
			</div>
		</div>
		<div x-data="toggleTernaryDemo">
			<p>
				Ternary:
				<strong x-text="answer.value"></strong>
				<span
					class="ml-2 inline-flex h-5 items-center rounded-4xl border border-amber-500/50 bg-amber-500/10 px-2 text-xs font-medium text-amber-700 dark:text-amber-400"
					x-show="answer.is(answer.ternary)"
				>neutral</span>
			</p>
			<div class="flex flex-wrap gap-2 mt-2">
				<Button @click="answer.toggle()">Yes / No</Button>
				<Button @click="answer.cycle()">Cycle all</Button>
				<Button variant="ghost" @click="answer.set(answer.ternary)">Unknown</Button>
			</div>
		</div>
	</div>
</DemoSection>
