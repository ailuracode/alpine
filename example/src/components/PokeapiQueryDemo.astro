---
interface Props {
	dataName: string;
	title: string;
	badgeClass?: string;
}

const { dataName, title, badgeClass = "badge-outline" } = Astro.props;
---

<article
	class="rounded-box border border-base-300 bg-base-200/50 p-4"
	x-data={dataName}
	x-init="init()"
	@destroy="destroy()"
>
	<h3 class="flex flex-wrap items-center gap-2 text-base font-semibold mb-2">
		{title}
		<span
			class:list={["badge badge-sm", badgeClass]}
			x-bind:class="{ 'badge-primary': query?.isSuccess }"
			x-text="badge"
		></span>
	</h3>

	<p class="text-sm text-error mt-2" x-show="query?.isError" x-text="query?.error?.message"></p>

	<div class="mt-3">
		<div
			class="query-table-wrap relative min-h-90 overflow-auto rounded-box border border-base-300 bg-base-100"
			x-bind:class="{
				'is-fetching': query?.isFetching && hasCachedPage,
				'is-awaiting-data': isAwaitingData,
			}"
			x-bind:aria-busy="isAwaitingData || query?.isFetching"
		>
			<table class="table table-sm table-zebra">
				<thead>
					<tr>
						<th scope="col">#</th>
						<th scope="col">Name</th>
					</tr>
				</thead>
				<tbody>
					<template x-for="row in tableRows" :key="page + '-' + row.id">
						<tr x-bind:class="{ 'is-loading': row.loading }">
							<td class="w-14 tabular-nums text-base-content/60">
								<span
									class="query-table-skeleton"
									x-show="row.loading"
									x-text="row.id"
									aria-hidden="true"
								></span>
								<span x-show="!row.loading" x-text="row.id"></span>
							</td>
							<td>
								<span
									class="query-table-skeleton"
									x-show="row.loading"
									x-text="row.name"
									aria-hidden="true"
								></span>
								<span x-show="!row.loading" x-text="row.name"></span>
							</td>
						</tr>
					</template>
				</tbody>
			</table>
		</div>
	</div>

	<div class="flex flex-wrap gap-2 mt-3">
		<button
			type="button"
			class="btn btn-sm btn-outline"
			@click="prevPage()"
			x-bind:disabled="page <= 1 || query?.isFetching"
		>
			Previous
		</button>
		<button
			type="button"
			class="btn btn-sm btn-outline"
			@click="query?.refetch()"
			x-bind:disabled="!query || query.isFetching"
		>
			Refresh
		</button>
		<button
			type="button"
			class="btn btn-sm btn-outline"
			@click="nextPage()"
			x-bind:disabled="!query?.data?.next || query?.isFetching"
		>
			Next
		</button>
	</div>
</article>
