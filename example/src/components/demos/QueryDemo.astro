---
import DemoSection from "../DemoSection.astro";
import PokeapiQueryDemo from "../PokeapiQueryDemo.astro";
---

<DemoSection title="Query" api="$store.query">
	<p class="text-sm text-muted-foreground">
		Three state adapters — pick one for <code>query(&#123; adapter &#125;)</code>, then register
		<code>$store.query</code>. Each column runs the same paginated
		<a href="https://pokeapi.co/" target="_blank" rel="noreferrer" class="text-primary underline-offset-4 hover:underline">PokeAPI</a>
		demo. Nanostores uses <code>$store.query</code> globally; Alpine.reactive and Zustand use
		<code>createQueryClient</code>. Open the <strong>Query</strong> devtools button (bottom-right) to inspect
		caches from all three adapters.
	</p>

	<div class="grid gap-4 mt-4">
		<PokeapiQueryDemo dataName="queryNanostoresAdapterDemo" title="Nanostores" badgeClass="bg-primary text-primary-foreground" />
		<PokeapiQueryDemo dataName="queryAlpineAdapterDemo" title="Alpine.reactive" />
		<PokeapiQueryDemo dataName="queryZustandAdapterDemo" title="Zustand" />
	</div>
</DemoSection>
