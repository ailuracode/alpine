---
import Button from "../astro/Button.astro";
import DemoSection from "../DemoSection.astro";
---

<DemoSection>
	<span slot="title">
		Attention <code class="text-muted-foreground font-normal">$wakelock</code> ·
		<code class="text-muted-foreground font-normal">$idle</code>
	</span>
	<div class="flex flex-wrap gap-2 mt-1">
		<Button
			x-show="$wakelock.isSupported"
			x-cloak
			@click="$wakelock.isActive ? $wakelock.release() : $wakelock.request()"
			x-bind:disabled="$wakelock.isRequesting"
		>
			<span x-text="$wakelock.isActive ? 'Allow sleep' : 'Keep screen awake'"></span>
		</Button>
		<Button
			x-show="$idle.isSupported && $idle.permission !== 'granted' && !$idle.isWatching"
			x-cloak
			@click="await $idle.requestPermission()"
			x-bind:disabled="$idle.isLoading"
		>
			Request idle permission
		</Button>
		<Button
			x-show="$idle.isSupported && $idle.permission === 'granted' && !$idle.isWatching"
			x-cloak
			@click="await $idle.start()"
			x-bind:disabled="$idle.isLoading"
		>
			Start idle detection
		</Button>
		<Button x-show="$idle.isWatching" x-cloak @click="$idle.stop()">
			Stop idle detection
		</Button>
	</div>
	<ul class="list-disc list-inside space-y-1 mt-3">
		<li>
			Wake lock:
			<strong x-text="$wakelock.isSupported ? ($wakelock.isActive ? 'active' : 'inactive') : 'unsupported'"></strong>
		</li>
		<li x-show="$idle.isSupported" x-cloak>
			Idle permission:
			<strong x-text="$idle.permission ?? 'unknown'"></strong>
		</li>
		<li x-show="$idle.isWatching" x-cloak>
			User: <strong x-text="$idle.userState"></strong> · Screen:
			<strong x-text="$idle.screenState"></strong>
		</li>
	</ul>
	<p class="text-sm text-muted-foreground mt-2" x-show="$idle.isSupported" x-cloak>
		Desktop: Chrome or Edge on localhost/HTTPS. Grant permission first, then start. Idle threshold is at least 1
		minute.
	</p>
	<p class="text-sm text-muted-foreground mt-2" x-show="!$wakelock.isSupported && !$idle.isSupported" x-cloak>
		Wake Lock and Idle Detection are not available in this browser.
	</p>
	<p class="text-sm text-destructive mt-2" x-show="$wakelock.error" x-cloak x-text="$wakelock.error"></p>
	<p class="text-sm text-destructive mt-2" x-show="$idle.error" x-cloak x-text="$idle.error"></p>
</DemoSection>
