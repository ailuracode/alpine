---
import Button from "../astro/Button.astro";
import DemoSection from "../DemoSection.astro";
---

<DemoSection title="Toast" api="$toast">
	<p class="text-sm text-muted-foreground">
		Headless queue — this demo renders Sonner-style stacks (shadcn/ui) in
		<code class="text-muted-foreground">SonnerToasts.astro</code> via
		<code class="text-muted-foreground">@ailuracode/alpine-toast</code> (not part of the plugin).
	</p>
	<div class="flex flex-wrap gap-2 mt-3">
		<Button @click="$toast('Hello from Alpine!')">Default</Button>
		<Button class="border-green-500/50 text-green-700 hover:bg-green-500/10 dark:text-green-400" @click="$toast.success('Saved')">
			Success
		</Button>
		<Button class="border-blue-500/50 text-blue-700 hover:bg-blue-500/10 dark:text-blue-400" @click="$toast.info({ content: { kind: 'badge', label: 'Pro plan', seats: 3 } })">
			Custom content
		</Button>
		<Button class="border-amber-500/50 text-amber-700 hover:bg-amber-500/10 dark:text-amber-400" @click="$toast.warning('Careful')">
			Warning
		</Button>
		<Button variant="destructive" @click="$toast.error('Failed')">Error</Button>
		<Button @click="$toast('Top center', { position: 'top-center' })">Top center</Button>
		<Button @click="$toast.warning({ title: 'File deleted', duration: false, action: { label: 'Undo' }, content: { kind: 'undo-demo' } })">
			Undo demo
		</Button>
		<Button @click="$toast.promise(function () { return new Promise(function (resolve) { setTimeout(function () { resolve('done') }, 1200) }) }, { loading: 'Saving...', success: 'Saved!', error: 'Failed' })">
			Promise
		</Button>
	</div>
</DemoSection>
