{
  "name": "@ailuracode/alpine",
  "private": true,
  "author": "ailuracode",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "pack:check": "node scripts/pack-check.mjs",
    "changeset:check": "changeset status",
    "test:packages": "pnpm -r --if-present test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm test && changeset publish",
    "publish:ci": "changeset publish",
    "publish:packages": "pnpm run release"
  },
  "devDependencies": {
    "@types/alpinejs": "^3.13.11",
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@vitest/coverage-v8": "^4.1.9",
    "alpinejs": "^3.15.12",
    "happy-dom": "^20.10.6",
    "vitest": "^4.1.9"
  }
}
