---
import Alert from "../astro/Alert.astro";
import Button from "../astro/Button.astro";
import DemoSection from "../DemoSection.astro";
---

<DemoSection title="Share" api="$share">
	<p class="text-sm text-muted-foreground" x-show="!$share.isSupported" x-cloak>
		Web Share API is not available in this browser.
	</p>
	<template x-if="$share.isSupported">
		<div>
			<Button @click="shared = await $share({ title: document.title, text: 'Check out this Alpine.js plugin demo', url: window.location.href })">
				Share page
			</Button>
			<Alert variant="success" class="mt-3" x-show="shared === true" x-cloak>
				<span>Thanks for sharing!</span>
			</Alert>
			<Alert variant="info" class="mt-3" x-show="shared === false" x-cloak>
				<span>Share cancelled.</span>
			</Alert>
		</div>
	</template>
</DemoSection>
